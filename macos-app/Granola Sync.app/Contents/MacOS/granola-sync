#!/bin/bash

# Granola Sync - launch sync from macOS app
# Update SCRIPT_PATH to point to your granola_sync.py location

SCRIPT_PATH="$HOME/Documents/Obsidian Vault/scripts/granola_sync.py"
PYTHONPATH_VAL="$HOME/Library/Python/3.9/lib/python/site-packages"

# Open Terminal, run script, and close window after completion
osascript <<EOF
tell application "Terminal"
    set newWindow to do script "export PYTHONPATH=\"$PYTHONPATH_VAL\" && /usr/bin/python3 \"$SCRIPT_PATH\"; sleep 2; exit"
    activate
end tell
EOF
